{
  "name": "typescript-monorepo",
  "version": "1.5.0",
  "description": "A quest for the perfect Typescript monorepo",
  "keywords": [
    "esm",
    "firebase",
    "firestore",
    "isolate-package",
    "monorepo",
    "nextjs",
    "turborepo",
    "typed-firestore",
    "typescript"
  ],
  "license": "MIT",
  "author": "Thijs Koerselman",
  "repository": {
    "type": "git",
    "url": "https://github.com/0x80/typescript-monorepo"
  },
  "scripts": {
    "prepare": "lefthook install",
    "check-types": "turbo check-types --continue",
    "check-format": "oxfmt --check",
    "build": "turbo build",
    "build:fns": "turbo build --filter=@repo/fns",
    "build:api": "turbo build --filter=@repo/api",
    "clean": "turbo clean",
    "dev": "turbo dev",
    "deploy": "firebase deploy",
    "watch": "turbo watch build --filter=@repo/core --filter=@repo/fns --filter=@repo/api",
    "test": "turbo test",
    "emulate": "firebase emulators:start --project demo-mono-ts",
    "format": "oxfmt",
    "check-lint": "turbo build && oxlint -c .oxlintrc.json --import-plugin --type-aware",
    "lint": "oxlint -c .oxlintrc.json --import-plugin --type-aware",
    "lint:fix": "oxlint -c .oxlintrc.json --import-plugin --type-aware --fix",
    "db:get-indexes": "firebase firestore:indexes > firestore.indexes.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "firebase-tools-with-isolate": "15.15.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
