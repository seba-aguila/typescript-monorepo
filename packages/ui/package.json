{
  "name": "@repo/ui",
  "version": "0.0.0",
  "description": "Shared UI components and styles",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./styles/globals.css": "./src/styles/globals.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "clean": "del-cli dist"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@codecompose/typescript-config": "^3.2.0",
    "@types/react": "^19.2.14",
    "del-cli": "^7.0.0",
    "react": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "tailwindcss": "^4.2.4"
  }
}
